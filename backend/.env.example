DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/activia_trace
# Docker: DATABASE_URL=postgresql+asyncpg://user:password@postgres:5432/activia_trace

# Security — CAMBIALAS. ENCRYPTION_KEY requiere exactamente 32 caracteres.
SECRET_KEY="change-me-to-a-random-string-at-least-32-chars!!"
ENCRYPTION_KEY="change-me-exactly-32-bytes-now!"

# CORS
ALLOWED_ORIGINS=http://localhost:5173

# Token
ACCESS_TOKEN_EXPIRE_MINUTES=15

# Observability
OTEL_SERVICE_NAME=activia-trace
OTEL_TRACES_EXPORTER=none

# Test database (override for local testing)
# DATABASE_URL_TEST="postgresql+asyncpg://user:password@localhost:5432/activia_trace_test"
